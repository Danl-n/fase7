# Copia este archivo como .env y completa con tus credenciales reales de MongoDB Atlas.
# NUNCA subas el archivo .env real al repositorio.

# Cadena de conexión de tu cluster de Atlas (Database > Connect > Drivers)
MONGO_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nombre de la base de datos
MONGO_DB=StreamMusic

# Clave secreta de Django para esta instalación (usa cualquier cadena aleatoria larga)
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

# True en desarrollo, False en producción
DJANGO_DEBUG=True
